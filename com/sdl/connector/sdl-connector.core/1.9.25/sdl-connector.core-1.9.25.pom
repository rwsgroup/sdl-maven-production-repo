                        <exclude>com/sdl/connector/core/servlets/SDLConfigurationCheckServlet.class</exclude>
                        <exclude>com/sdl/connector/core/services/impl/ExecutorInstanceServiceImpl*</exclude>
                    </excludes>
                </configuration>
                <executions>
                    <execution>
                        <goals>
                            <goal>prepare-agent</goal>
                        </goals>
                    </execution>
                    <execution>
                        <id>jacoco-report</id>
                        <phase>test</phase>
                        <goals>
                            <goal>report</goal>
                        </goals>
                    </execution>
                    &lt;!&ndash;Add this checking &ndash;&gt;
