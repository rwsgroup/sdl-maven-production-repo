                                        </limit>
                                    </limits>
                                </rule>
                            </rules>
                        </configuration>
                    </execution>

                </executions>
            </plugin>-->
        </plugins>
    </build>

    <dependencies>
		<dependency>
            <groupId>org.osgi</groupId>
